# -----------------------------------------------------------------------------
# INTEL ARCHIVE - ENVIRONMENT CONFIGURATION TEMPLATE
# -----------------------------------------------------------------------------

# DATABASE
# For local dev: file:./dev.db
# For production (Vercel/Neon): postgres://user:password@host/db
DATABASE_URL="file:./dev.db"

# AUTHENTICATION
# Generate with: npx auth secret
AUTH_SECRET="your_secret_here"

# NEXTAUTH URL
# For local dev: http://localhost:3000
# For production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# INTEL SETTINGS
NEXT_PUBLIC_APP_NAME="INTEL ARCHIVE"
NEXT_PUBLIC_CLEARANCE_LEVEL="5"
